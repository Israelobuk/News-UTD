# If using Vercel multi-service routePrefix:
# VITE_API_BASE_URL=https://your-frontend-domain/_/backend
# VITE_WS_URL=wss://your-frontend-domain/_/backend/ws/alerts
# VITE_WATCHLIST_URL=https://your-frontend-domain/_/backend/api/watchlist
VITE_API_BASE_URL=https://your-backend-domain
VITE_WS_URL=wss://your-backend-domain/ws/alerts
VITE_WATCHLIST_URL=https://your-backend-domain/api/watchlist
